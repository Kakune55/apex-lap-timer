{
	"name": "apex-lap-timer",
	"type": "module",
	"scripts": {
		"dev": "npm run build:frontend && wrangler dev",
		"dev:frontend": "vite --port=3000 --host=0.0.0.0",
		"build:frontend": "vite build && node scripts/prepare-pwa.mjs",
		"deploy": "npm run build:frontend && wrangler deploy --minify",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"hash-password": "node scripts/gen-password-hash.mjs"
	},
	"dependencies": {
		"hono": "^4.12.5",
		"leaflet": "^1.9.4",
		"lucide-react": "^0.546.0",
		"motion": "^12.23.24",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-leaflet": "^5.0.0",
		"recharts": "^3.3.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.1.14",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^25.3.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.0.4",
		"tailwindcss": "^4.1.14",
		"vite": "^7.1.7",
		"wrangler": "^4.71.0"
	}
}
